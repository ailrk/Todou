{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "Todou",
  "version": "0.1.0",
  "identifier": "com.tauri.dev",
  "build": {
    "frontendDist": "../data/todou/",
    "devUrl": "http://localhost:5555"
  },
  "app": {
    "windows": [
      {
        "title": "Todou",
        "width": 400,
        "height": 820,
        "resizable": true,
        "fullscreen": false
      }
    ],
    "security": {
      "csp": null
    }
  },
  "bundle": {
    "active": true,
    "targets": "all",
    "externalBin": [
    "binaries/todou"
    ],
    "icon": [
      "icons/32x32.png",
      "icons/128x128.png",
      "icons/icon.icns",
      "icons/icon.ico"
    ]
  }
}
